<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme -->
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@color/indigo_700</item>
        <item name="android:navigationBarColor">@color/indigo_900</item>
    </style>

    <!-- Splash screen theme - shown briefly while activity loads -->
    <style name="Theme.SplashScreen" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/indigo_700</item>
        <item name="android:navigationBarColor">@color/indigo_900</item>
    </style>
</resources>
